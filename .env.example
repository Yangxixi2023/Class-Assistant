OPENAI_API_KEY=sk-Erx4xGFbYgmbVQoirISk76rVcNOb5KTYWIVEg8ygvMIyGPT5
# 快速模式专用密钥（如果快速模型需要不同的 key，填在这里；留空则用主密钥）
